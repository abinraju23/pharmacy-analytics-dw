  <DataSources>
    <DataSource Name="Pharmacy_DW">
      <DataSourceReference>Pharmacy_DW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>dc18a65d-8ae1-4ba6-a5db-49ddca4e4ebf</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT
    dt.Year,
    dt.MonthName,
    COUNT(f.FactKey)                          AS TotalPrescriptions,
    COUNT(DISTINCT f.PatientKey)              AS TotalPatients,
    COUNT(DISTINCT d.DrugName)                AS TotalDistinctDrugs,
    CAST(AVG(f.DurationDays) AS DECIMAL(5,1)) AS AvgDurationDays,
    CAST(
        SUM(CASE WHEN f.IsIVRoute = 1
                 THEN 1 ELSE 0 END) * 100.0
        / COUNT(f.FactKey)
    AS DECIMAL(5,2))                          AS IVPercentage,
    SUM(CASE WHEN f.IsMainDrug = 1
             THEN 1 ELSE 0 END)               AS MainDrugCount,
    SUM(CASE WHEN f.IsFormulary = 1
             THEN 1 ELSE 0 END)               AS FormularyCount,
    (SELECT COUNT(DISTINCT PatientKey)
     FROM dbo.Fact_Prescription)              AS TotalUniquePatients,
    (SELECT COUNT(DISTINCT d2.DrugName)
     FROM dbo.Fact_Prescription f2
     JOIN dbo.Dim_Drug d2
     ON f2.DrugKey = d2.DrugKey)              AS TotalDistinctDrugsAllTime,
    COUNT(DISTINCT CASE
        WHEN p.ClinicalPathway = 'Both'
        THEN f.PatientKey END)                AS PatientsBoth,
    COUNT(DISTINCT CASE
        WHEN p.ClinicalPathway = 'Prescriptions Only'
        THEN f.PatientKey END)                AS PatientsPrescOnly,
    COUNT(DISTINCT CASE
        WHEN p.ClinicalPathway = 'Procedures Only'
        THEN f.PatientKey END)                AS PatientsProcOnly
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_Drug d     ON f.DrugKey    = d.DrugKey
JOIN dbo.Dim_Patient p  ON f.PatientKey = p.PatientKey
JOIN dbo.Dim_Date dt    ON f.DateKey    = dt.DateKey
WHERE p.IsCurrent = 1
AND dt.Year &gt;= (SELECT MAX(Year) - 9 FROM dbo.Dim_Date)
GROUP BY dt.Year, dt.MonthName
ORDER BY dt.Year DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="MonthName">
          <DataField>MonthName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalPrescriptions">
          <DataField>TotalPrescriptions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalPatients">
          <DataField>TotalPatients</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalDistinctDrugs">
          <DataField>TotalDistinctDrugs</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvgDurationDays">
          <DataField>AvgDurationDays</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="IVPercentage">
          <DataField>IVPercentage</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MainDrugCount">
          <DataField>MainDrugCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FormularyCount">
          <DataField>FormularyCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalUniquePatients">
          <DataField>TotalUniquePatients</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalDistinctDrugsAllTime">
          <DataField>TotalDistinctDrugsAllTime</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PatientsBoth">
          <DataField>PatientsBoth</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PatientsPrescOnly">
          <DataField>PatientsPrescOnly</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PatientsProcOnly">
          <DataField>PatientsProcOnly</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
