  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Pharmacy_DW">
      <DataSourceReference>Pharmacy_DW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>204a543f-c791-47af-b9e1-108a82704354</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT TOP 15
    diag.ShortTitle                             AS DiagnosisName,
    diag.LongTitle                              AS DiagnosisDetail,
    COUNT(f.FactKey)                            AS TotalPrescriptions,
    COUNT(DISTINCT f.PatientKey)                AS UniquePatients,
    COUNT(DISTINCT d.DrugName)                  AS DistinctDrugs,
    CAST(AVG(f.DurationDays) AS DECIMAL(5,1))   AS AvgDurationDays,
    CAST(MAX(f.DurationDays) AS DECIMAL(5,1))   AS MaxDurationDays,
    SUM(CASE WHEN f.IsIVRoute = 1
             THEN 1 ELSE 0 END)                 AS IVPrescriptions,
    CAST(
        SUM(CASE WHEN f.IsIVRoute = 1
                 THEN 1 ELSE 0 END) * 100.0
        / COUNT(f.FactKey)
    AS DECIMAL(5,2))                            AS IVPercentage,
    CAST(
        COUNT(f.FactKey) * 1.0
        / COUNT(DISTINCT f.PatientKey)
    AS DECIMAL(5,1))                            AS AvgPrescriptionsPerPatient
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_Diagnosis diag ON f.DiagnosisKey = diag.DiagnosisKey
JOIN dbo.Dim_Drug d         ON f.DrugKey      = d.DrugKey
JOIN dbo.Dim_Patient p      ON f.PatientKey   = p.PatientKey
WHERE diag.IsPrimary = 1
AND diag.ShortTitle != 'No Diagnosis Recorded'
AND p.IsCurrent = 1
GROUP BY diag.ShortTitle, diag.LongTitle
ORDER BY TotalPrescriptions DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DiagnosisName">
          <DataField>DiagnosisName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DiagnosisDetail">
          <DataField>DiagnosisDetail</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalPrescriptions">
          <DataField>TotalPrescriptions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="UniquePatients">
          <DataField>UniquePatients</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DistinctDrugs">
          <DataField>DistinctDrugs</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvgDurationDays">
          <DataField>AvgDurationDays</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MaxDurationDays">
          <DataField>MaxDurationDays</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="IVPrescriptions">
          <DataField>IVPrescriptions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="IVPercentage">
          <DataField>IVPercentage</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="AvgPrescriptionsPerPatient">
          <DataField>AvgPrescriptionsPerPatient</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_MortalityRisk">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT
    SUM(CASE WHEN drg.DRGMortality = 4
             THEN 1 ELSE 0 END)         AS ExtremeMortalityRx,
    COUNT(DISTINCT f.PatientKey)        AS TotalPatients,
    CAST(
        SUM(CASE WHEN drg.DRGMortality = 4
                 THEN 1 ELSE 0 END) * 100.0
        / COUNT(f.FactKey)
    AS DECIMAL(5,2))                    AS ExtremeMortalityPct
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_DRG drg        ON f.DRGKey       = drg.DRGKey
JOIN dbo.Dim_Diagnosis diag ON f.DiagnosisKey = diag.DiagnosisKey
WHERE diag.IsPrimary = 1
AND diag.ShortTitle != 'No Diagnosis Recorded'
AND drg.DRGMortality IS NOT NULL
AND drg.DRGMortality != 0</CommandText>
      </Query>
      <Fields>
        <Field Name="ExtremeMortalityRx">
          <DataField>ExtremeMortalityRx</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalPatients">
          <DataField>TotalPatients</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ExtremeMortalityPct">
          <DataField>ExtremeMortalityPct</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_DBSource">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT
    SUM(CASE WHEN i.DBSource = 'metavision'
             THEN 1 ELSE 0 END)         AS MetavisionRx,
    SUM(CASE WHEN i.DBSource = 'carevue'
             THEN 1 ELSE 0 END)         AS CarevueRx
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_ICUStay i      ON f.ICUStayKey   = i.ICUStayKey
JOIN dbo.Dim_Diagnosis diag ON f.DiagnosisKey = diag.DiagnosisKey
WHERE diag.IsPrimary = 1
AND i.FirstCareUnit != 'No ICU Stay'
AND diag.ShortTitle != 'No Diagnosis Recorded'</CommandText>
      </Query>
      <Fields>
        <Field Name="MetavisionRx">
          <DataField>MetavisionRx</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CarevueRx">
          <DataField>CarevueRx</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
