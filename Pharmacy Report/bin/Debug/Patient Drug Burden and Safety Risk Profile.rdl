  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Pharmacy_DW">
      <DataSourceReference>Pharmacy_DW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ba28739f-5929-4a0d-a07a-83a12e821ab2</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT
    p.Subject_ID                                        AS PatientID,
    p.Gender,
    i.FirstCareUnit                                     AS CareUnit,
    p.ClinicalPathway,
    diag.ShortTitle                                     AS PrimaryDiagnosis,
    COUNT(DISTINCT d.DrugName)                          AS DistinctDrugs,
    CAST(MAX(i.ICU_LOS_Days) AS DECIMAL(10,1))          AS TotalICU_LOS,
    CASE
        WHEN COUNT(DISTINCT d.DrugName) &gt; 20
        THEN 'HIGH RISK'
        WHEN COUNT(DISTINCT d.DrugName) &gt; 10
        THEN 'MODERATE'
        ELSE 'NORMAL'
    END                                                 AS RiskLevel,
    (SELECT TOP 1 d2.DrugName
     FROM dbo.Fact_Prescription f2
     JOIN dbo.Dim_Drug d2 ON f2.DrugKey = d2.DrugKey
     WHERE f2.PatientKey = f.PatientKey
     AND d2.DrugType = 'MAIN'
     GROUP BY d2.DrugName
     ORDER BY COUNT(*) DESC)                            AS MostPrescribedDrug,
    (SELECT COUNT(DISTINCT pr.ProcedureKey)
     FROM dbo.Fact_Prescription pr
     WHERE pr.PatientKey = f.PatientKey
     AND pr.ProcedureKey != -1)                         AS TotalProcedures
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_Patient p      ON f.PatientKey   = p.PatientKey
JOIN dbo.Dim_Drug d         ON f.DrugKey      = d.DrugKey
JOIN dbo.Dim_ICUStay i      ON f.ICUStayKey   = i.ICUStayKey
JOIN dbo.Dim_Diagnosis diag ON f.DiagnosisKey = diag.DiagnosisKey
WHERE p.IsCurrent = 1
AND i.FirstCareUnit != 'No ICU Stay'
AND diag.IsPrimary = 1
GROUP BY
    p.Subject_ID,
    p.Gender,
    i.FirstCareUnit,
    p.ClinicalPathway,
    diag.ShortTitle,
    f.PatientKey
ORDER BY TotalICU_LOS DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="PatientID">
          <DataField>PatientID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Gender">
          <DataField>Gender</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CareUnit">
          <DataField>CareUnit</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ClinicalPathway">
          <DataField>ClinicalPathway</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PrimaryDiagnosis">
          <DataField>PrimaryDiagnosis</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DistinctDrugs">
          <DataField>DistinctDrugs</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalICU_LOS">
          <DataField>TotalICU_LOS</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="RiskLevel">
          <DataField>RiskLevel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MostPrescribedDrug">
          <DataField>MostPrescribedDrug</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalProcedures">
          <DataField>TotalProcedures</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_MostCommonDiagnosis">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT TOP 1
    diag.ShortTitle         AS MostCommonDiagnosis,
    COUNT(f.FactKey)        AS DiagnosisCount
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_Diagnosis diag ON f.DiagnosisKey = diag.DiagnosisKey
JOIN dbo.Dim_Patient p      ON f.PatientKey   = p.PatientKey
WHERE diag.IsPrimary = 1
AND diag.ShortTitle != 'No Diagnosis Recorded'
AND p.IsCurrent = 1
GROUP BY diag.ShortTitle
ORDER BY COUNT(f.FactKey) DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="MostCommonDiagnosis">
          <DataField>MostCommonDiagnosis</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DiagnosisCount">
          <DataField>DiagnosisCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_MostPrescribedDrug">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT TOP 1
    d.DrugName              AS MostPrescribedDrug,
    COUNT(f.FactKey)        AS TotalCount
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_Drug d ON f.DrugKey = d.DrugKey
WHERE d.DrugType = 'MAIN'
AND d.DrugName != 'Unknown Drug'
GROUP BY d.DrugName
ORDER BY COUNT(f.FactKey) DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="MostPrescribedDrug">
          <DataField>MostPrescribedDrug</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalCount">
          <DataField>TotalCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
