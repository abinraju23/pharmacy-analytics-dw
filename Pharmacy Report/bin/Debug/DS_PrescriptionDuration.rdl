  </am:AuthoringMetadata>
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Pharmacy_DW">
      <DataSourceReference>Pharmacy_DW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3e3aa5bc-e0d0-4441-84e8-2fc01ee9997b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Pharmacy_DW</DataSourceName>
        <CommandText>SELECT
    d.DrugType,
    i.FirstCareUnit,
    COUNT(f.FactKey)                          AS TotalPrescriptions,
    CAST(AVG(f.DurationDays) AS DECIMAL(5,1)) AS AvgDurationDays,
    CAST(MAX(f.DurationDays) AS DECIMAL(5,1)) AS MaxDurationDays,
    CAST(MIN(f.DurationDays) AS DECIMAL(5,1)) AS MinDurationDays,
    SUM(CASE WHEN f.DurationDays &gt; 7
             THEN 1 ELSE 0 END)               AS LongDurationCount,
    CAST(
        SUM(CASE WHEN f.DurationDays &gt; 7
                 THEN 1 ELSE 0 END) * 100.0
        / COUNT(f.FactKey)
    AS DECIMAL(5,2))                          AS LongDurationPct
FROM dbo.Fact_Prescription f
JOIN dbo.Dim_Drug d     ON f.DrugKey    = d.DrugKey
JOIN dbo.Dim_ICUStay i  ON f.ICUStayKey = i.ICUStayKey
WHERE i.FirstCareUnit != 'No ICU Stay'
AND d.DrugType != 'Unknown'
GROUP BY d.DrugType, i.FirstCareUnit
ORDER BY  AvgDurationDays DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="DrugType">
          <DataField>DrugType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FirstCareUnit">
          <DataField>FirstCareUnit</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalPrescriptions">
          <DataField>TotalPrescriptions</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvgDurationDays">
          <DataField>AvgDurationDays</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MaxDurationDays">
          <DataField>MaxDurationDays</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MinDurationDays">
          <DataField>MinDurationDays</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="LongDurationCount">
          <DataField>LongDurationCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LongDurationPct">
          <DataField>LongDurationPct</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
