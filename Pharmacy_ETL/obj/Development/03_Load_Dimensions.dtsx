                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    d.icd9_code,
    dd.short_title,
    dd.long_title,
    CASE WHEN d.seq_num = 1
         THEN 1 ELSE 0
    END AS IsPrimary
FROM dbo.DIAGNOSES_ICD d
