            <component
              refId="Package\Data Flow Task\Source - Prescriptions"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;4"
              description="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server."
              name="Source - Prescriptions"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement used by the component to extract data."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    pr.subject_id,
    pr.hadm_id,
    pr.icustay_id,
    pr.startdate,
    pr.drug,
    pr.drug_type,
    pr.formulary_drug_cd,
    pr.dose_val_rx,
    pr.route,
    CASE WHEN pr.route IN
        ('IV','IV DRIP','IV BOLUS','IVPCA')
         THEN 1 ELSE 0
    END                             AS IsIVRoute,
    CASE WHEN pr.drug_type = 'MAIN'
         THEN 1 ELSE 0
    END                             AS IsMainDrug,
    CASE WHEN pr.formulary_drug_cd IS NOT NULL
         THEN 1 ELSE 0
    END                             AS IsFormulary,
    CASE
        WHEN pr.enddate &gt; pr.startdate
        THEN DATEDIFF(DAY, pr.startdate, pr.enddate)
        ELSE 0
    END                             AS DurationDays,
    -- Primary procedure for this admission
    (SELECT TOP 1 pc.icd9_code
     FROM dbo.PROCEDURES_ICD pc
     WHERE pc.hadm_id = pr.hadm_id
     AND pc.seq_num = 1)            AS proc_code,
    -- Primary diagnosis for this admission
    (SELECT TOP 1 d.icd9_code
     FROM dbo.DIAGNOSES_ICD d
     WHERE d.hadm_id = pr.hadm_id
     AND d.seq_num = 1)             AS diag_code,
    -- DRG for this admission
    (SELECT TOP 1 drg.drg_code
     FROM dbo.DRGCODES drg
     WHERE drg.hadm_id = pr.hadm_id) AS drg_code
FROM dbo.PRESCRIPTIONS pr
WHERE pr.startdate IS NOT NULL</property>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">30</property>
                <property
                  dataType="System.Boolean"
                  description="Indicates whether to allow non-string external columns to be implicitly converted to strings at the output columns."
                  name="AllowImplicitStringConversion">true</property>
                <property
                  dataType="System.String"
                  description="The Source database table name."
                  expressionType="Notify"
                  name="TableOrViewName"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor"></property>
                <property
                  dataType="System.Int32"
                  description="Specify the mode to retrieve external column information"
                  name="AccessMode"
                  typeConverter="Microsoft.SqlServer.Dts.Pipeline.DataReaderSourceAdapter+EnumToStringConverter">2</property>
                <property
                  dataType="System.String"
                  name="UserComponentTypeName">Microsoft.DataReaderSourceAdapter</property>
              </properties>
