      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3EC865C8-CDF7-47C4-A563-6E6448D3F852}"
          SQLTask:SqlStatementSource="SET IDENTITY_INSERT dbo.Dim_Procedure ON;&#xA;INSERT INTO dbo.Dim_Procedure&#xA;    (ProcedureKey,ICD9_Code,ShortTitle,LongTitle,SeqNum,IsPrimary)&#xA;VALUES (-1,'N/A','No Procedure Recorded',&#xA;    'Patient had no associated ICD-9 procedure code',0,0);&#xA;SET IDENTITY_INSERT dbo.Dim_Procedure OFF;&#xA;&#xA;SET IDENTITY_INSERT dbo.Dim_ICUStay ON;&#xA;INSERT INTO dbo.Dim_ICUStay&#xA;    (ICUStayKey,ICUStay_ID,FirstCareUnit,LastCareUnit,DBSource,ICU_LOS_Days)&#xA;VALUES (-1,-1,'No ICU Stay','No ICU Stay','N/A',0);&#xA;SET IDENTITY_INSERT dbo.Dim_ICUStay OFF;&#xA;&#xA;SET IDENTITY_INSERT dbo.Dim_Diagnosis ON;&#xA;INSERT INTO dbo.Dim_Diagnosis&#xA;    (DiagnosisKey,ICD9_Code,ShortTitle,LongTitle,IsPrimary)&#xA;VALUES (-1,'N/A','No Diagnosis Recorded',&#xA;    'Patient had no associated ICD-9 diagnosis code',0);&#xA;SET IDENTITY_INSERT dbo.Dim_Diagnosis OFF;&#xA;&#xA;SET IDENTITY_INSERT dbo.Dim_DRG ON;&#xA;INSERT INTO dbo.Dim_DRG&#xA;    (DRGKey,DRGType,DRGCode,DRGDescription,DRGSeverity,DRGMortality)&#xA;VALUES (-1,'N/A',-1,'No DRG Code Recorded',0,0);&#xA;SET IDENTITY_INSERT dbo.Dim_DRG OFF;&#xA;&#xA;SET IDENTITY_INSERT dbo.Dim_Drug ON;&#xA;INSERT INTO dbo.Dim_Drug&#xA;    (DrugKey,DrugName,DrugNameGeneric,DrugType,&#xA;     FormularyCode,NDC,Route,RouteCategory,DoseUnit,ProdStrength)&#xA;VALUES (-1,'Unknown Drug','Unknown','UNKNOWN',&#xA;    'N/A','N/A','N/A','Other','N/A','N/A');&#xA;SET IDENTITY_INSERT dbo.Dim_Drug OFF;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate DW Tables"
