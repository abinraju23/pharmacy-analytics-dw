      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3EC865C8-CDF7-47C4-A563-6E6448D3F852}"
          SQLTask:SqlStatementSource="-- Step 1: Drop all FK constraints&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_Date;&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_Patient;&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_Drug;&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_ICUStay;&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_Procedure;&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_Diagnosis;&#xA;ALTER TABLE dbo.Fact_Prescription DROP CONSTRAINT FK_Fact_DRG;&#xA;&#xA;-- Step 2: Truncate everything&#xA;TRUNCATE TABLE dbo.Fact_Prescription;&#xA;TRUNCATE TABLE dbo.Dim_Date;&#xA;TRUNCATE TABLE dbo.Dim_Patient;&#xA;TRUNCATE TABLE dbo.Dim_Drug;&#xA;TRUNCATE TABLE dbo.Dim_ICUStay;&#xA;TRUNCATE TABLE dbo.Dim_Procedure;&#xA;TRUNCATE TABLE dbo.Dim_Diagnosis;&#xA;TRUNCATE TABLE dbo.Dim_DRG;&#xA;&#xA;-- Step 3: Recreate all FK constraints&#xA;ALTER TABLE dbo.Fact_Prescription ADD&#xA;    CONSTRAINT FK_Fact_Date&#xA;        FOREIGN KEY (DateKey) REFERENCES dbo.Dim_Date(DateKey),&#xA;    CONSTRAINT FK_Fact_Patient&#xA;        FOREIGN KEY (PatientKey) REFERENCES dbo.Dim_Patient(PatientKey),&#xA;    CONSTRAINT FK_Fact_Drug&#xA;        FOREIGN KEY (DrugKey) REFERENCES dbo.Dim_Drug(DrugKey),&#xA;    CONSTRAINT FK_Fact_ICUStay&#xA;        FOREIGN KEY (ICUStayKey) REFERENCES dbo.Dim_ICUStay(ICUStayKey),&#xA;    CONSTRAINT FK_Fact_Procedure&#xA;        FOREIGN KEY (ProcedureKey) REFERENCES dbo.Dim_Procedure(ProcedureKey),&#xA;    CONSTRAINT FK_Fact_Diagnosis&#xA;        FOREIGN KEY (DiagnosisKey) REFERENCES dbo.Dim_Diagnosis(DiagnosisKey),&#xA;    CONSTRAINT FK_Fact_DRG&#xA;        FOREIGN KEY (DRGKey) REFERENCES dbo.Dim_DRG(DRGKey);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
